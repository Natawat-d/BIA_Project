        <mxCell id="bd_infra" value="INFRASTRUCTURE / DEVOPS   ·   🐳 containerized  ·  ☁️ hosts &amp; runs the entire stack above" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#F5FBF6;strokeColor=#CCCCCC;verticalAlign=top;align=left;fontStyle=1;fontSize=12;fontColor=#555555;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="90" y="543" width="1070" height="120" as="geometry" />
        </mxCell>

        <!-- ================= PRESENTATION ================= -->
        <mxCell id="t_streamlit" value="🟥 &lt;b&gt;Streamlit&lt;/b&gt;&lt;br&gt;Dashboard UI — multi-page&lt;br&gt;(Home · Descriptive · Churn Risk · Retention Sim)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE9E9;strokeColor=#FF4B4B;fontColor=#333333;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
