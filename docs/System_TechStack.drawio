<mxfile host="app.diagrams.net" type="device">
  <diagram id="netflix-dss-stack" name="Technology Stack">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Netflix Customer Retention DSS  —  Technology Stack" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;fontColor=#111111;" vertex="1" parent="1">
          <mxGeometry x="90" y="18" width="1070" height="34" as="geometry" />
        </mxCell>

        <!-- left "uses" arrow -->
        <mxCell id="usesarrow" value="each layer uses the one below" style="endArrow=block;html=1;rounded=0;strokeColor=#999999;strokeWidth=2;fontColor=#888888;fontSize=11;horizontal=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="62" y="110" as="sourcePoint" />
            <mxPoint x="62" y="650" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ================= LAYER BANDS ================= -->
        <mxCell id="bd_pres" value="PRESENTATION LAYER   ·   Frontend / UI" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFF6F6;strokeColor=#CCCCCC;verticalAlign=top;align=left;fontStyle=1;fontSize=12;fontColor=#555555;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="90" y="70" width="1070" height="95" as="geometry" />
        </mxCell>
        <mxCell id="bd_app" value="APPLICATION LAYER   ·   Logic &amp; Runtime" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#F5FAFE;strokeColor=#CCCCCC;verticalAlign=top;align=left;fontStyle=1;fontSize=12;fontColor=#555555;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="90" y="180" width="1070" height="78" as="geometry" />
        </mxCell>
        <mxCell id="bd_ana" value="ANALYTICS &amp; ML LAYER   ·   data processing + modeling" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFFAF2;strokeColor=#CCCCCC;verticalAlign=top;align=left;fontStyle=1;fontSize=12;fontColor=#555555;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="90" y="273" width="1070" height="120" as="geometry" />
        </mxCell>
        <mxCell id="bd_data" value="DATA &amp; STORAGE LAYER" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#F4F8FB;strokeColor=#CCCCCC;verticalAlign=top;align=left;fontStyle=1;fontSize=12;fontColor=#555555;spacingLeft=12;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="90" y="408" width="1070" height="120" as="geometry" />
